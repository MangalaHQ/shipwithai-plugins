# ============================================================
# Better Auth — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Required — Auth
BETTER_AUTH_SECRET=          # openssl rand -hex 32 (min 32 chars)
BETTER_AUTH_URL=http://localhost:3000   # exact app URL, no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required — Database (uncomment ONE)
# DATABASE_URL=file:sqlite.db                          # SQLite (local dev)
# DATABASE_URL=postgresql://user:pass@localhost:5432/db # PostgreSQL
# TURSO_DATABASE_URL=libsql://your-db.turso.io         # Turso
# TURSO_AUTH_TOKEN=                                     # Turso auth token

# Optional — Email (logs to console without this)
RESEND_API_KEY=              # https://resend.com — free tier: 100 emails/day

# Optional — OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
